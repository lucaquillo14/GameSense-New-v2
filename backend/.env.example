# Required for Roboflow inference (detect API, football models, and shooting technique RF-DETR).
ROBOFLOW_API_KEY=your_key_here

# Optional shooting technique settings:
# Goal/ball model defaults to ball-and-goalpost-detection-2/10 (Roboflow Universe).
# Override with another model ID, or set it empty to disable goal detection.
# ROBOFLOW_GOAL_MODEL=ball-and-goalpost-detection-2/10
# SHOOTING_TECHNIQUE_BACKEND=hosted
# SHOOTING_TECHNIQUE_BALL_CONF=0.30
# SHOOTING_TECHNIQUE_PLAYER_HEIGHT_M=1.75
# SHOOTING_TECHNIQUE_GOAL_WIDTH_M=7.32
# SHOOTING_TECHNIQUE_KICKING_FOOT=auto

# Optional max-speed tracking settings:
# Player detection cadence in frames (default targets 15 Hz). Lower = more
# inference calls and denser tracking, higher = faster processing.
# TRACK_DETECT_CADENCE=2
# Pitch keypoint model used for dynamic (moving-camera) calibration.
# ROBOFLOW_PITCH_MODEL=football-field-detection-f07vi/15
# Real goal-frame size used for goal-post scale calibration (defaults are
# FIFA full-size). Override for training goals of other sizes.
# GOAL_WIDTH_M=7.32
# GOAL_HEIGHT_M=2.44
